  <DataSets>
    <DataSet Name="Call_Center">
      <Query>
        <DataSourceName>CallCenter</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>Select * from Call_Center</CommandText>
      </Query>
      <Fields>
        <Field Name="call_id">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>call_id</DataField>
        </Field>
        <Field Name="date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>date</DataField>
        </Field>
