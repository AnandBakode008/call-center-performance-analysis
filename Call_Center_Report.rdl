          <rd:TypeName>System.TimeSpan</rd:TypeName>
          <DataField>avgtalkduration</DataField>
        </Field>
        <Field Name="satisfaction_rating">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>satisfaction_rating</DataField>
        </Field>
        <Field Name="talk_seconds">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>talk_seconds</DataField>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!agent.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue>=Parameters!AgentP.Value(0)</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!date.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!StartDate.Value(0)</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!date.Value</FilterExpression>
          <Operator>In</Operator>
          <FilterValues>
            <FilterValue>=Parameters!EndDate.Value(0)</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
    <DataSet Name="Agent_DropDown">
      <Query>
        <DataSourceName>CallCenter</DataSourceName>
        <CommandText>Select Distinct agent from Call_Center</CommandText>
      </Query>
      <Fields>
        <Field Name="agent">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>agent</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="StartDrop">
      <Query>
        <DataSourceName>CallCenter</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT distinct date::date AS only_date
FROM Call_center;</CommandText>
      </Query>
      <Fields>
        <Field Name="only_date">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>only_date</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EndDrop">
      <Query>
        <DataSourceName>CallCenter</DataSourceName>
        <CommandText>SELECT  distinct DATE(date) AS only_End
FROM Call_center;</CommandText>
      </Query>
      <Fields>
        <Field Name="only_end">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>only_end</DataField>
        </Field>
      </Fields>
    </DataSet>
